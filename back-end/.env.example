# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/shared_calendar

# JWT (session cookie)
JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_TTL=7d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must match the Authorized redirect URI in the Google console:
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# 32-byte hex key for AES-256-GCM (encrypts Google refresh tokens at rest)
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=
